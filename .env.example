# Database (Render sets DATABASE_URL automatically)
DATABASE_URL=

# Auth
JWT_SECRET=change-this-to-a-random-secret

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Features
DEV_AUTO_VERIFY=false
DEV_AUTO_PREMIUM=false
